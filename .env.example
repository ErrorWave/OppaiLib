# ── OppaiLib configuration ──────────────────────────────────────────────
# Copy to .env and edit. All values have sane defaults except the passphrase.

# HTTP listen address inside the container
OPPAI_HTTP_ADDR=:8080

# Persistent paths (map these to host volumes on Unraid)
OPPAI_MEDIA_DIR=/media
OPPAI_CONFIG_DIR=/config
OPPAI_DB_PATH=/db/oppailib.sqlite

# Master encryption passphrase. REQUIRED on first run; used to derive the KEK.
# If empty, the server prints a generated one on first boot — save it somewhere
# safe. LOSING THIS MEANS LOSING YOUR LIBRARY. There is no recovery by design.
OPPAI_PASSPHRASE=

# First-run admin account (only used to bootstrap; ignored after user exists)
OPPAI_ADMIN_USER=admin
OPPAI_ADMIN_PASSWORD=

# AI auto-tagging
OPPAI_AI_ENABLED=true
# The default (onnx) image bakes the wd14 tagger in here. /config is a bind mount
# on most setups, so a model placed under /config/models would be hidden unless
# you put it there yourself — in which case point this at /config/models.
OPPAI_AI_MODEL_DIR=/opt/oppailib/models
# cpu | cuda  (cuda requires GPU passthrough; falls back to cpu with a warning)
OPPAI_AI_DEVICE=cpu
# Frames sampled per video/GIF before merging their tags (capped at 32). Each
# frame costs one ffmpeg decode + one inference. Video tagging needs ffmpeg.
OPPAI_AI_VIDEO_FRAMES=5

# Scraper politeness
OPPAI_SCRAPE_DELAY_MS=1500
# Defaults to a browser-like User-Agent so sites that gate OpenGraph metadata
# (or block unknown agents) still return the real page. Set this to advertise
# the tool honestly, e.g. "OppaiLib/0.1 (+self-hosted)".
# OPPAI_SCRAPE_USER_AGENT=
# Honor robots.txt before fetching. Default true. Set to "false" if a site you
# own/are authorized to archive disallows crawlers and Fetch returns
# "blocked by robots.txt".
OPPAI_SCRAPE_RESPECT_ROBOTS=true

# F95 login. Most f95zone.to game threads are members-only; sign in with an F95
# account to scrape them. Leave blank to scrape only public threads. These are just
# the startup default — the Settings screen can set them at runtime, and the
# password there is write-only (never sent back to the browser).
# OPPAI_F95_USERNAME=
# OPPAI_F95_PASSWORD=

# Image generation. URL of a local image generator on your network, used by the
# "Create" tab: an InvokeAI server (default port 9090) or an Automatic1111 / SD.Next
# one (the /sdapi/v1 flavour, default port 7860). Which API it speaks is detected
# automatically. Blank disables the feature. Prompts stay on your own hardware —
# nothing is sent to a cloud service. The Settings screen can set this at runtime.
# OPPAI_IMAGEGEN_URL=http://192.168.1.10:9090

# Libby chat. Point this at an OpenAI-compatible server such as LM Studio,
# llama.cpp, or Ollama's /v1 bridge. The Chat tab is disabled until both are set.
# OPPAI_CHAT_URL=http://192.168.1.10:1234
# OPPAI_CHAT_MODEL=local-model-name

# Session lifetime
OPPAI_SESSION_TTL_HOURS=720

# Set to "true" to log at debug level
OPPAI_DEBUG=false
