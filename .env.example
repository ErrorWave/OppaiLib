# ── OppaiLib configuration ──────────────────────────────────────────────
# Copy to .env and edit. All values have sane defaults except the passphrase.

# HTTP listen address inside the container
OPPAI_HTTP_ADDR=:8080

# Persistent paths (map these to host volumes on Unraid)
OPPAI_MEDIA_DIR=/media
OPPAI_CONFIG_DIR=/config
OPPAI_DB_PATH=/db/oppailib.sqlite

# Master encryption passphrase. REQUIRED on first run; used to derive the KEK.
# If empty, the server prints a generated one on first boot — save it somewhere
# safe. LOSING THIS MEANS LOSING YOUR LIBRARY. There is no recovery by design.
OPPAI_PASSPHRASE=

# First-run admin account (only used to bootstrap; ignored after user exists)
OPPAI_ADMIN_USER=admin
OPPAI_ADMIN_PASSWORD=

# AI auto-tagging
OPPAI_AI_ENABLED=true
OPPAI_AI_MODEL_DIR=/config/models
# cpu | cuda  (cuda requires GPU passthrough; falls back to cpu if unavailable)
OPPAI_AI_DEVICE=cpu

# Scraper politeness
OPPAI_SCRAPE_DELAY_MS=1500
OPPAI_SCRAPE_USER_AGENT=OppaiLib/0.1 (+self-hosted)

# Session lifetime
OPPAI_SESSION_TTL_HOURS=720

# Set to "true" to log at debug level
OPPAI_DEBUG=false
