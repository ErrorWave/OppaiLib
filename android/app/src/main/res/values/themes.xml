<resources>
    <!-- Base theme; the actual UI colors come from Compose Material 3 (dynamic
         color / Material You). This only styles the window before Compose draws,
         so it follows the system light/dark setting instead of always flashing
         black — see values-night for the dark variant. -->
    <style name="Theme.OppaiLib" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
